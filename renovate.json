{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "schedule": [
    "on the 1st day of the month"
  ],
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchDepNames": ["go"],
      "matchDepTypes": ["golang"],
      "rangeStrategy": "bump"
    }
  ],
  "pinDigests": true,
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ]
}
